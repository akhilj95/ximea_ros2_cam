<launch shutdown_timeout="5.0">
    <group>
        <node pkg="ximea_ros2_cam" exec="ximea_ros2_cam_node" name="ximea_nir_node" namespace="ximea_nir" output="screen">
            <param name="serial_no" value="'41102142'" />
            <param name="camera_name" value="ximea_nir" />
            <param name="camera_info_url" value="" />
            <param name="frame_id" value="nir_link" />
            
            <param name="poll_open_period_s" value="2.0" />
            <param name="poll_frame_period_s" value="0.001" />
            
            <param name="num_cams_in_bus" value="2" />
            <param name="bw_safety_ratio" value="0.9" /> 
            <param name="publish_xi_image_info" value="true" />
            <param name="use_hardware_timestamps" value="true" />
            
            <param from="$(find-pkg-share ximea_ros2_cam)/config/nir_config.yaml" />
        </node>
    </group>

    <group>
        <node pkg="ximea_ros2_cam" exec="ximea_ros2_cam_node" name="ximea_rgb_node" namespace="ximea_rgb" output="screen">
            <param name="serial_no" value="'14206951'" />
            <param name="camera_name" value="ximea_rgb" />
            <param name="camera_info_url" value="" />
            <param name="frame_id" value="rgb_link" />
            
            <param name="poll_open_period_s" value="3.0" />
            <param name="poll_frame_period_s" value="0.001" />
            
            <param name="num_cams_in_bus" value="2" />
            <param name="bw_safety_ratio" value="0.9" /> 
            <param name="publish_xi_image_info" value="true" />
            <param name="use_hardware_timestamps" value="true" />

            <param from="$(find-pkg-share ximea_ros2_cam)/config/rgb_config.yaml" />
        </node>
    </group>
</launch>